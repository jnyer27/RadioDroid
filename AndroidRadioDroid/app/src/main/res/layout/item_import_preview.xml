<?xml version="1.0" encoding="utf-8"?>
<!-- One row in the CHIRP import preview list. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Destination slot, e.g. "→ Ch 12" -->
    <TextView
        android:id="@+id/importSlot"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="?colorPrimary"
        android:text="→ Ch 1" />

    <!-- Channel details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Name -->
            <TextView
                android:id="@+id/importName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="NAME" />

            <!-- Frequency -->
            <TextView
                android:id="@+id/importFreq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:text="462.5500 MHz" />

        </LinearLayout>

        <!-- TX tone, RX tone, duplex/offset (non-interactive chips) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/importChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleLine="false"
            app:chipSpacingHorizontal="6dp"
            app:chipSpacingVertical="4dp" />

        <!-- Comment / source location from CSV -->
        <TextView
            android:id="@+id/importComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorSecondary"
            android:text="" />

    </LinearLayout>

</LinearLayout>
