<?xml version="1.0" encoding="utf-8"?>
<!--
    XTAL 671 Calculator
    Standalone tool — computes the nicFW XTAL correction value from a measured
    frequency error.  Formula (matches Google Sheets reference):
        ROUND(((ActualFreq - TargetFreq) * 100_000) / TargetFreq * 671.08864, 0)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:title="XTAL 671 Calculator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── ⚠ Prerequisites warning ───────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#FFF3CD"
                app:strokeColor="#FFCC00"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠  Before calibrating"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#7D5700"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="#7D5700"
                        android:text="Set the radio&apos;s XTAL 671 value to 0 before measuring the actual RX frequency. A non-zero XTAL setting will skew the measurement and produce an incorrect correction value." />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Info banner ───────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.3"
                android:textColor="?android:attr/textColorSecondary"
                android:text="Enter the target (expected) frequency and the frequency your radio actually receives. The calculator returns the nicFW XTAL 671 correction value to enter in the radio settings." />

            <!-- ── Target Frequency ──────────────────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutTargetFreq"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Target Frequency (MHz)"
                app:helperText="Expected / license frequency — e.g. 462.7250 for GMRS22"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTargetFreq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:text="462.7250"
                    android:imeOptions="actionNext"
                    android:selectAllOnFocus="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Actual RX Frequency ───────────────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutActualFreq"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Actual RX Frequency (MHz)"
                app:helperText="Frequency measured by a calibrated reference receiver"
                android:layout_marginBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editActualFreq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionDone"
                    android:selectAllOnFocus="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Common target frequency presets ──────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Common targets:"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPresets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:singleSelection="false">

                <!-- GMRS channels (most common calibration references) -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGmrs22"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GMRS22 462.725" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGmrs1"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GMRS1 462.5625" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMurs1"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MURS1 151.820" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWx1"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WX1 162.400" />

            </com.google.android.material.chip.ChipGroup>

            <!-- ── Result card ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XTAL 671 Correction Value"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:textColor="?android:attr/textColorSecondary"
                        android:paddingBottom="4dp" />

                    <!-- Large result number -->
                    <TextView
                        android:id="@+id/textResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:paddingBottom="4dp" />

                    <!-- Error / frequency delta line -->
                    <TextView
                        android:id="@+id/textDelta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="?android:attr/textColorSecondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Direction hint ────────────────────────────────────────── -->
            <TextView
                android:id="@+id/textDirection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- ── Copy button ───────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Copy Value to Clipboard"
                android:enabled="false"
                android:layout_marginBottom="16dp" />

            <!-- ── Divider + formula reference ───────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Formula reference"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ROUND( ((Actual − Target) × 100000) ÷ Target × 671.08864, 0 )"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?android:attr/textColorSecondary"
                android:text="Positive → radio receives HIGH (actual &gt; target). Increase XTAL value.\nNegative → radio receives LOW (actual &lt; target). Decrease XTAL value.\nZero → calibration is within rounding tolerance." />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
