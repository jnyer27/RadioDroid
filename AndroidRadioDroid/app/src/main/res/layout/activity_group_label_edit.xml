<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Edit Group Labels" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- One row per group A–O -->

            <include layout="@layout/item_group_label_row" android:id="@+id/rowA" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowB" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowC" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowD" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowE" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowF" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowG" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowH" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowI" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowJ" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowK" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowL" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowM" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowN" />
            <include layout="@layout/item_group_label_row" android:id="@+id/rowO" />

        </LinearLayout>
    </ScrollView>

    <!-- Sticky button row at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:elevation="4dp"
        android:background="?android:attr/windowBackground">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGroupCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGroupSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ok" />

    </LinearLayout>
</LinearLayout>
