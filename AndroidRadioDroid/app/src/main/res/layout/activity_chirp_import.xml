<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:title="Import CHIRP CSV" />

    <!-- Scrollable content: summary + group assignment + preview list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Summary ─────────────────────────────────────────────────── -->
            <TextView
                android:id="@+id/textImportSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="16dp" />

            <!-- ── Group assignment ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Assign Groups to All Imported Channels"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- Row 1: Group 1 + Group 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Group 1"
                        android:textSize="12sp" />
                    <Spinner
                        android:id="@+id/spinnerImportGroup1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Group 2"
                        android:textSize="12sp" />
                    <Spinner
                        android:id="@+id/spinnerImportGroup2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Row 2: Group 3 + Group 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Group 3"
                        android:textSize="12sp" />
                    <Spinner
                        android:id="@+id/spinnerImportGroup3"
                        android:layout_width="match_parent"
                        android:layout_height="48dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Group 4"
                        android:textSize="12sp" />
                    <Spinner
                        android:id="@+id/spinnerImportGroup4"
                        android:layout_width="match_parent"
                        android:layout_height="48dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── TX Power override ────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TX Power (All Imported Channels)"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />
            <Spinner
                android:id="@+id/spinnerImportPower"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp" />

            <!-- ── Starting channel ─────────────────────────────────────────── -->
            <TextView
                android:id="@+id/labelStartSlot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Starting Channel"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />
            <Spinner
                android:id="@+id/spinnerStartSlot"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp" />

            <!-- ── Divider ──────────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Channel Preview"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <!-- ── Preview rows added programmatically ──────────────────────── -->
            <LinearLayout
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <!-- Sticky bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnImportCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnImportConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Import" />

    </LinearLayout>

</LinearLayout>
