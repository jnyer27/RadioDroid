<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="2dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:minHeight="56dp">

        <!-- Row 1: Global parameters (frequency, name, mode, bandwidth, duplex, power, tones) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/channelNumber"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Ch 1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:id="@+id/channelFreq"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:text="146.5200" />
                <TextView
                    android:id="@+id/channelName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/channelToneGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/channelTxTone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:text="" />
                <TextView
                    android:id="@+id/channelRxTone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="8dp">
                <TextView
                    android:id="@+id/channelDuplex"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:text="" />
                <TextView
                    android:id="@+id/channelPower"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:text="" />
                <TextView
                    android:id="@+id/channelSlot1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:text="" />
                <TextView
                    android:id="@+id/channelSlot2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:text="" />
            </LinearLayout>

            <ImageView
                android:id="@+id/channelDragHandle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:padding="8dp"
                android:src="@drawable/ic_drag_handle"
                android:contentDescription="Drag to reorder"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Row 2: Driver-specific (e.g. Groups Slot 1–4) — below and to the right -->
        <LinearLayout
            android:id="@+id/channelDriverRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:layout_marginTop="4dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/channelDriverLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?android:attr/textColorTertiary"
                android:text="@string/channel_driver_specific_label" />
            <TextView
                android:id="@+id/channelGroups"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary"
                android:text="" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
