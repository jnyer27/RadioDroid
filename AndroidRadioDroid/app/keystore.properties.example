# Copy to keystore.properties and fill in. Do not commit keystore.properties or your .jks file.
# Create a release keystore (one-time):
#   keytool -genkey -v -keystore radiodroid-release.keystore -alias radiodroid -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=radiodroid-release.keystore
storePassword=your_store_password
keyAlias=radiodroid
keyPassword=your_key_password
